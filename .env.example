# FINORA local configuration template.
# Copy to .env and provide secrets locally. Never commit populated values.

# Credentialed market-data providers
ALPHA_VANTAGE_API_KEY=
TIINGO_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
NASDAQ_DATA_LINK_API_KEY=
FMP_API_KEY=
SEC_USER_AGENT=

# Models and local cache
FINORA_CHRONOS_MODEL_ID=amazon/chronos-t5-tiny
FINORA_FINBERT_MODEL_ID=ProsusAI/finbert
FINORA_MODEL_CACHE_DIR=model_cache
FINORA_LLM_PROVIDER=gpt_oss
FINORA_LLM_MODEL_ID=gpt-oss-120b
FINORA_LLM_ENDPOINT=
FINORA_LLM_API_KEY=
FINORA_LLM_MODE=remote
FINORA_LLM_MAX_CONTEXT=131072
FINORA_LLM_MAX_TOKENS=4096
FINORA_LLM_TEMPERATURE=0.1

# API and services
AURUM_ENV=dev
AURUM_API_KEY=
AURUM_DATABASE_PATH=data/aurum.sqlite3
AURUM_SENTIMENT_BACKEND=lexical
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
FINORA_POSTGRES_PASSWORD=
MLFLOW_TRACKING_URI=file:./mlruns
